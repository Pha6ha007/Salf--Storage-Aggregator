# Test Environment Variables
# Copy this file to .env.test for running tests

NODE_ENV=test

# Test Database (use separate database for tests)
DATABASE_URL=postgresql://test_user:test_password@localhost:5432/storagecompare_test?schema=public

# Test Redis (use separate Redis DB)
REDIS_URL=redis://localhost:6379/1

# JWT (use test secrets)
JWT_SECRET=test-jwt-secret-for-unit-tests-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# API Configuration
API_PREFIX=api/v1
PORT=3001

# External Services (use test/mock keys)
GOOGLE_MAPS_API_KEY=test-google-maps-key
AWS_REGION=me-south-1
AWS_S3_BUCKET=test-bucket
AWS_ACCESS_KEY_ID=test-aws-key
AWS_SECRET_ACCESS_KEY=test-aws-secret
SENDGRID_API_KEY=test-sendgrid-key
SENDGRID_FROM=test@storagecompare.ae
TWILIO_ACCOUNT_SID=test-twilio-sid
TWILIO_AUTH_TOKEN=test-twilio-token
TWILIO_PHONE_NUMBER=+971501234567
TWILIO_WHATSAPP_NUMBER=whatsapp:+971501234567
ANTHROPIC_API_KEY=test-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
