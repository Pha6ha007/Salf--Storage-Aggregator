# ============================================
# Environment Variables Template
# ============================================
# Copy this file to .env for local development
# For production, see .env.production.example files in backend/frontend
# ============================================

# ============================================
# Backend Environment Variables
# ============================================

# Node Environment
NODE_ENV=development
PORT=3001

# API Configuration
API_PREFIX=api/v1

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://storage:storage_dev_pass@localhost:5432/storagecompare?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# AWS S3 (for media uploads)
AWS_REGION=me-south-1
AWS_S3_BUCKET=storagecompare-media-dev
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# SendGrid (for emails)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=noreply@storagecompare.ae

# Twilio (for SMS and WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+971xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+971xxxxxxxxx

# Anthropic Claude API (for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Paddle (for payments)
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_ENVIRONMENT=sandbox
PADDLE_SELLER_ID=your-paddle-seller-id

# ============================================
# Frontend Environment Variables
# ============================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps API Key (same as backend)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Notes for Development:
# ============================================
# 1. Use Docker Compose for local development (see DOCKER.md)
# 2. External services (SendGrid, Twilio, etc.) are optional in development
# 3. Generate JWT_SECRET: openssl rand -base64 32
# 4. Get Google Maps API key: https://console.cloud.google.com/
# 5. For production deployment, see DEPLOYMENT.md
