# ============================================
# Production Environment Variables (Vercel)
# ============================================
# Set these in Vercel dashboard under Settings → Environment Variables
# ============================================

# Backend API URL (Railway)
NEXT_PUBLIC_API_URL=https://api-storagecompare.up.railway.app/api/v1

# Site URL (Vercel)
NEXT_PUBLIC_SITE_URL=https://storagecompare.vercel.app

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App Environment
NODE_ENV=production

# ============================================
# Notes:
# ============================================
# 1. All NEXT_PUBLIC_* variables are exposed to the browser
# 2. Never include secrets in NEXT_PUBLIC_* variables
# 3. Update NEXT_PUBLIC_API_URL after Railway deployment
# 4. Update NEXT_PUBLIC_SITE_URL with your custom domain if using one
# 5. Google Maps API key should have HTTP Referrer restrictions in Google Console
