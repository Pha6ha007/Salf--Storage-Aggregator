# ============================================
# Docker Compose Environment Variables
# ============================================
# Copy this file to .env for local development
# cp .env.docker .env
# ============================================

# ============================================
# General Settings
# ============================================
NODE_ENV=production
COMPOSE_PROJECT_NAME=storagecompare

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_DB=storagecompare
POSTGRES_USER=storage
POSTGRES_PASSWORD=storage_secure_password_change_me
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# Backend API
# ============================================
BACKEND_PORT=3001
API_PREFIX=api/v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# ============================================
# Frontend
# ============================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# External Services (Optional)
# ============================================

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# AWS S3 (for media uploads)
AWS_REGION=me-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SendGrid (for emails)
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@storagecompare.ae

# Twilio (for SMS and WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Anthropic Claude API (for AI features)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Paddle (for payments)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
PADDLE_SELLER_ID=

# ============================================
# Notes:
# ============================================
# 1. Never commit .env file with real credentials
# 2. Generate strong JWT_SECRET: openssl rand -base64 32
# 3. Use strong POSTGRES_PASSWORD in production
# 4. External services are optional for local development
# 5. Frontend environment variables must start with NEXT_PUBLIC_
